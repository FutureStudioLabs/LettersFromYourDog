# Vite exposes only variables prefixed with VITE_
# https://vitejs.dev/guide/env-and-mode.html
#
# Copy to `.env` for local dev, or set these in Vercel → Environment Variables.

# --- Supabase (Project Settings → API) ---
# Use the project URL and the publishable (anon) key — never the service_role key in the frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
#
# Dashboard → Storage: bucket id must be `dog` (photos). Then run:
# supabase/migrations/20260429170000_storage_dog_bucket.sql
#
# --- Stripe Payment Link ---
# VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/...
VITE_STRIPE_PAYMENT_LINK=

# --- Confirmation page (/confirmation) after Stripe redirect ---
# Stripe Dashboard: success URL → https://YOUR_DOMAIN/confirmation
# VITE_SUCCESS_REACH_OUT_BY=May 27
# VITE_SUCCESS_FIRST_CHARGE_DATE=May 1
VITE_SUCCESS_REACH_OUT_BY=
VITE_SUCCESS_FIRST_CHARGE_DATE=
